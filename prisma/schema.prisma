generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model businesses {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id                   String?   @db.Uuid
  business_name               String
  business_desc               String?
  website                     String?
  revenue                     String?
  employees                   String?
  business_type               String?
  geographic_focus            String[]
  ideal_client_industries     String[]
  referral_partner_industries String[]
  priorities                  String[]
  open_to_matching            Boolean?  @default(true)
  created_at                  DateTime? @default(now()) @db.Timestamptz(6)
  members                     members?  @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  offers offers[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model members {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name String
  last_name  String
  email      String       @unique
  phone      String?
  linkedin   String?
  stage      String?
  industry   String?
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  businesses businesses[]
  events     events[]
  offers offers[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  role         String   @default("MEMBER")
  avatarUrl    String?
}

model events {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  date        String
  time        String
  location    String
  category    String
  price       String
  host        String
  attendees   Int         @default(0)
  capacity    Int         @default(50)
  featured    Boolean     @default(false)
  status      EventStatus @default(PENDING)
  member_id   String?     @db.Uuid
  created_At  DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?   @db.Timestamptz(6)
  duration    String      @default("2 hrs")
  tags        String[]    @default([])
  members     members?    @relation(fields: [member_id], references: [id], onDelete: Cascade)
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

model offers {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id String? @db.Uuid
  business_id String? @db.Uuid
  business_name String
  category String
  type String
  discount_value String?
  title String
  description String
  location String?
  expiry_date DateTime
  fe_discount String?
  events_page_url String?
  how_to_redeem String?
  is_affiliate Boolean @default(false)
  status String @default("PENDING")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  members                 members?    @relation(fields: [member_id], references: [id], onDelete: SetNull)
  businesses              businesses? @relation(fields: [business_id], references: [id], onDelete: SetNull)
}

