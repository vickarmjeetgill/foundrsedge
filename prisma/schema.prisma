generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model businesses {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id                   String?   @db.Uuid
  business_name               String
  business_desc               String?
  website                     String?
  revenue                     String?
  employees                   String?
  business_type               String?
  geographic_focus            String[]
  ideal_client_industries     String[]
  referral_partner_industries String[]
  priorities                  String[]
  open_to_matching            Boolean?  @default(true)
  created_at                  DateTime? @default(now()) @db.Timestamptz(6)
  members                     members?  @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  offers                      offers[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model members {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name String
  last_name  String
  email      String       @unique
  phone      String?
  linkedin   String?
  stage      String?
  industry   String?
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  businesses businesses[]
  events     events[]
  offers     offers[]
  nominations nominations[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  role         String   @default("MEMBER")
  avatarUrl    String?
}

model offers {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id       String?     @db.Uuid
  business_id     String?     @db.Uuid
  business_name   String
  category        String
  type            String
  discount_value  String?
  title           String
  description     String
  location        String?
  expiry_date     DateTime
  fe_discount     String?
  events_page_url String?
  how_to_redeem   String?
  is_affiliate    Boolean     @default(false)
  status          String      @default("PENDING")
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  updated_at      DateTime    @updatedAt @db.Timestamptz(6)
  featured        Boolean     @default(false)
  businesses      businesses? @relation(fields: [business_id], references: [id])
  members         members?    @relation(fields: [member_id], references: [id])
}

model events {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  date        String
  time        String
  location    String
  category    String
  price       String
  host        String
  attendees   Int         @default(0)
  featured    Boolean     @default(false)
  status      EventStatus @default(PENDING)
  member_id   String?     @db.Uuid
  created_At  DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?   @db.Timestamptz(6)
  tags        String[]    @default([])
  capacity    Int         @default(50)
  duration    String      @default("2 hrs")
  members     members?    @relation(fields: [member_id], references: [id], onDelete: Cascade)
}

model comments {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id         String         @db.Uuid
  parent_id       String?        @db.Uuid
  author_name     String
  author_business String?
  content         String
  like_count      Int            @default(0)
  removed         Boolean        @default(false)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @db.Timestamptz(6)
  posts           posts          @relation(fields: [post_id], references: [id], onDelete: Cascade)
  flag_reports    flag_reports[]
}

model flag_reports {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content_type    String
  content_id      String    @db.Uuid
  content_preview String
  author_name     String
  reported_by     String
  reason          String
  details         String?
  status          String    @default("pending")
  reported_at     DateTime  @default(now()) @db.Timestamptz(6)
  post_id         String?   @db.Uuid
  comment_id      String?   @db.Uuid
  comments        comments? @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  posts           posts?    @relation(fields: [post_id], references: [id], onDelete: Cascade)
}

model posts {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_name     String
  author_business String?
  content         String
  linked_type     String?
  linked_title    String?
  linked_subtitle String?
  linked_url      String?
  like_count      Int            @default(0)
  comment_count   Int            @default(0)
  flag_count      Int            @default(0)
  removed         Boolean        @default(false)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @db.Timestamptz(6)
  comments        comments[]
  flag_reports    flag_reports[]
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

model awards {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  org              String
  category         String
  region           String
  deadline         String   
  award_date       String   @map("awardDate")
  value            String
  cycle            String
  desc             String
  featured         Boolean  @default(false)
  nominationsOpen Boolean  @default(true) @map("nominationsOpen")
  sponsor          String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @updatedAt @db.Timestamptz(6)

  nominations nominations[]
}

model nominations {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  award_id String @db.Uuid
  member_id String? @db.Uuid
  business_name String
  contact_name String
  contact_email String
  website String?
  achievement String
  statement String
  status String @default("PENDING")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  award awards @relation(fields: [award_id], references: [id], onDelete: Cascade)
  members members? @relation(fields: [member_id], references: [id], onDelete: SetNull)  
}
